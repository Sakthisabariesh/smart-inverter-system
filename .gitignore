# ── Smart Inverter — Root .gitignore ──────────────────────────────────

# NEVER commit real secrets
.env
.env.*
!**/.env.example

# Node.js dependencies
node_modules/
npm-debug.log*

# Flutter build output
**/build/
**/.dart_tool/
**/.flutter-plugins-dependencies
**/.pub-cache/
**/android/app/debug/
**/android/app/profile/
**/android/app/release/

# IDE files
.idea/
*.iml

# OS files
.DS_Store
Thumbs.db
